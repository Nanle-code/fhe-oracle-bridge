# Copy this file to .env and fill in your values
#   cp .env.example .env
#
# Never commit `.env` — it is listed in `.gitignore`. Only this example file
# belongs in git.

# Your deployer private key (no 0x prefix needed)
PRIVATE_KEY=your_private_key_here

# RPC endpoints
ARBITRUM_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc

# Contract addresses (filled in after deploy.js — or copy from frontend/config.json)
# Run: npm run setup:env
ACCESS_REGISTRY=0x3b01F41557C08587c83c1EcA40ef93bb6829D223
FHE_ORACLE_BRIDGE=0x4c1A39704D65992464C4BE356c1A0BA001526dC3
MOCK_CONSUMER=0x2B826A58AB77E474c2A3a6C9B8cc521F33AA3d8c
PRIVATE_LIQUIDATOR=0x5d9DD91F4d8D8bF1c7Df801c6a0453316f4Af3ff
PRIVATE_THRESHOLD_ALERTS=0x80886CCF7253337E1ABe911CD36f1F7BAAdB1932

# Optional second/third feeders for quorum (Wave 3)
# FEEDER2_PRIVATE_KEY=
# FEEDER3_PRIVATE_KEY=

# Optional: for contract verification on Etherscan
ETHERSCAN_API_KEY=

# Keeper / feeder tuning
# KEEPER_POLL_MS=8000
# KEEPER_FROM_BLOCK=0
# KEEPER_LOG_JSON=1
# FEEDER_INTERVAL_MS=60000
# FEEDER_LOG_JSON=1

# Liquidation demo (CoinGecko+Binance — not dummy prices)
# LIQ_PREMIUM_BPS=500
# CRASH_BPS=1500
# COLLATERAL_ETH=0.005
# POSITION_ID=1
# SKIP_INITIAL_SUBMIT=1   # use existing oracle round (skip first encrypt/submit)

# Demo helpers: npm run demo:preflight  |  npm run wave5:live:wait  |  npm run wave4:live:wait

# Local dashboard URL for health checks
# FRONTEND_URL=http://127.0.0.1:8765/
# PORT=8765

# Optional: Discord alert when npm run testnet:smoke fails
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
