# Copy this file to .env and fill in your values
#   cp .env.example .env
#
# Never commit `.env` — it is listed in `.gitignore`. Only this example file
# belongs in git.

# Your deployer private key (no 0x prefix needed)
PRIVATE_KEY=your_private_key_here

# RPC endpoints
ARBITRUM_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc

# Contract addresses (filled in after deploy.js runs)
ACCESS_REGISTRY=
FHE_ORACLE_BRIDGE=
MOCK_CONSUMER=
PRIVATE_LIQUIDATOR=

# Optional: for contract verification on Etherscan
ETHERSCAN_API_KEY=
