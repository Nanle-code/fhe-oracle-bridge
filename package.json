{
  "name": "fhe-oracle-bridge",
  "version": "1.0.0",
  "description": "Privacy-preserving price oracle using Fhenix FHE",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy:local": "hardhat run scripts/deploy.js --network hardhat",
    "deploy:helium": "hardhat run scripts/deploy.js --network helium",
    "deploy:arbitrum-sepolia": "NODE_OPTIONS='--dns-result-order=ipv4first' hardhat run scripts/deploy.js --network arbitrumSepolia",
    "deploy:base-sepolia": "NODE_OPTIONS='--dns-result-order=ipv4first' hardhat run scripts/deploy.js --network baseSepolia",
    "submit:local": "hardhat run scripts/submitPrice.js --network hardhat",
    "submit:helium": "hardhat run scripts/submitPrice.js --network helium",
    "submit:arbitrum-sepolia": "NODE_OPTIONS='--dns-result-order=ipv4first' hardhat run scripts/submitPrice.js --network arbitrumSepolia",
    "submit:base-sepolia": "NODE_OPTIONS='--dns-result-order=ipv4first' hardhat run scripts/submitPrice.js --network baseSepolia",
    "feeder:local": "hardhat run scripts/feederDaemon.js --network hardhat",
    "feeder:arbitrum-sepolia": "NODE_OPTIONS='--dns-result-order=ipv4first' hardhat run scripts/feederDaemon.js --network arbitrumSepolia",
    "feeder:base-sepolia": "NODE_OPTIONS='--dns-result-order=ipv4first' hardhat run scripts/feederDaemon.js --network baseSepolia",
    "keeper:arbitrum-sepolia": "NODE_OPTIONS='--dns-result-order=ipv4first' hardhat run scripts/liquidationKeeper.js --network arbitrumSepolia",
    "keeper:base-sepolia": "NODE_OPTIONS='--dns-result-order=ipv4first' hardhat run scripts/liquidationKeeper.js --network baseSepolia",
    "keeper:threshold:arbitrum-sepolia": "NODE_OPTIONS='--dns-result-order=ipv4first' hardhat run scripts/thresholdAlertKeeper.js --network arbitrumSepolia",
    "keeper:threshold:base-sepolia": "NODE_OPTIONS='--dns-result-order=ipv4first' hardhat run scripts/thresholdAlertKeeper.js --network baseSepolia",
    "alert:register:arbitrum-sepolia": "NODE_OPTIONS='--dns-result-order=ipv4first' hardhat run scripts/registerThresholdAlert.js --network arbitrumSepolia",
    "alert:register:base-sepolia": "NODE_OPTIONS='--dns-result-order=ipv4first' hardhat run scripts/registerThresholdAlert.js --network baseSepolia",
    "alert:prepare:arbitrum-sepolia": "NODE_OPTIONS='--dns-result-order=ipv4first' hardhat run scripts/prepareThresholdCheck.js --network arbitrumSepolia",
    "alert:prepare:base-sepolia": "NODE_OPTIONS='--dns-result-order=ipv4first' hardhat run scripts/prepareThresholdCheck.js --network baseSepolia",
    "demo:arbitrum": "bash scripts/run-arbitrum-demo.sh",
    "frontend": "node scripts/serveFrontend.cjs",
    "deploy:frontend:surge": "surge frontend/ https://fhe-oracle-bridge-demo.surge.sh",
    "node": "hardhat node",
    "health:check": "node scripts/monitoring/healthMonitor.js --network hardhat",
    "health:check:arbitrum-sepolia": "node scripts/monitoring/healthMonitor.js --network arbitrumSepolia",
    "health:check:base-sepolia": "node scripts/monitoring/healthMonitor.js --network baseSepolia",
    "performance:monitor": "node scripts/monitoring/performanceMonitor.js --network hardhat",
    "performance:monitor:arbitrum-sepolia": "node scripts/monitoring/performanceMonitor.js --network arbitrumSepolia",
    "performance:monitor:base-sepolia": "node scripts/monitoring/performanceMonitor.js --network baseSepolia",
    "performance:report": "node scripts/monitoring/performanceMonitor.js --network hardhat --report",
    "performance:report:arbitrum-sepolia": "node scripts/monitoring/performanceMonitor.js --network arbitrumSepolia --report",
    "performance:report:base-sepolia": "node scripts/monitoring/performanceMonitor.js --network baseSepolia --report",
    "deploy:automated": "node scripts/deploy/automatedDeploy.js --network",
    "deploy:automated:hardhat": "node scripts/deploy/automatedDeploy.js --network hardhat",
    "deploy:automated:arbitrum-sepolia": "node scripts/deploy/automatedDeploy.js --network arbitrumSepolia",
    "deploy:automated:base-sepolia": "node scripts/deploy/automatedDeploy.js --network baseSepolia",
    "deploy:automated:skip-verify": "node scripts/deploy/automatedDeploy.js --network hardhat --skip-verification",
    "demo:all": "npm run demo:liquidation && npm run demo:multi-feeder && npm run demo:threshold-alerts",
    "demo:liquidation": "hardhat run scripts/demoLiquidationKeeper.js --network hardhat",
    "demo:multi-feeder": "hardhat run scripts/demoMultiFeeder.js --network hardhat",
    "demo:threshold-alerts": "hardhat run scripts/demoThresholdAlerts.js --network hardhat",
    "submit:live:arbitrum-sepolia": "NODE_OPTIONS='--dns-result-order=ipv4first' hardhat run scripts/submitPrice.js --network arbitrumSepolia",
    "wave4:live": "NODE_OPTIONS='--dns-result-order=ipv4first' hardhat run scripts/wave4LiveE2E.js --network arbitrumSepolia",
    "wave4:open": "NODE_OPTIONS='--dns-result-order=ipv4first' hardhat run scripts/openPositionLive.js --network arbitrumSepolia",
    "wave4:trigger": "NODE_OPTIONS='--dns-result-order=ipv4first' hardhat run scripts/requestLiquidationCheck.js --network arbitrumSepolia",
    "wave4:complete": "NODE_OPTIONS='--dns-result-order=ipv4first' hardhat run scripts/completeLiquidationOnce.js --network arbitrumSepolia",
    "wave4:continue": "NODE_OPTIONS='--dns-result-order=ipv4first' hardhat run scripts/wave4LiveContinue.js --network arbitrumSepolia",
    "wave4:finish": "NODE_OPTIONS='--dns-result-order=ipv4first' hardhat run scripts/wave4FinishLiquidation.js --network arbitrumSepolia",
    "spin": "bash scripts/spin.sh",
    "spin:stop": "bash scripts/spin-stop.sh",
    "spin:logs": "tail -f logs/spin/*.log",
    "testnet:smoke": "NODE_OPTIONS='--dns-result-order=ipv4first' node scripts/testnetSmoke.js",
    "testnet:smoke:strict": "NODE_OPTIONS='--dns-result-order=ipv4first' node scripts/testnetSmoke.js --strict",
    "testnet:health": "NODE_OPTIONS='--dns-result-order=ipv4first' node scripts/testnetHealth.js",
    "testnet:health:json": "NODE_OPTIONS='--dns-result-order=ipv4first' node scripts/testnetHealth.js --json",
    "wave5:live": "NODE_OPTIONS='--dns-result-order=ipv4first' hardhat run scripts/wave5LiveE2E.js --network arbitrumSepolia",
    "cron:smoke": "NODE_OPTIONS='--dns-result-order=ipv4first' node scripts/testnetSmoke.js",
    "setup:feeder2": "NODE_OPTIONS='--dns-result-order=ipv4first' hardhat run scripts/setupSecondFeeder.js --network arbitrumSepolia",
    "feeds:quorum": "NODE_OPTIONS='--dns-result-order=ipv4first' hardhat run scripts/createQuorumFeeds.js --network arbitrumSepolia",
    "wave3:quorum": "NODE_OPTIONS='--dns-result-order=ipv4first' hardhat run scripts/wave3LiveQuorum.js --network arbitrumSepolia",
    "wave5:complete": "NODE_OPTIONS='--dns-result-order=ipv4first' hardhat run scripts/completeThresholdAlertOnce.js --network arbitrumSepolia",
    "demo:live:wave4": "bash scripts/run-live-demos.sh wave4",
    "demo:live:wave5": "bash scripts/run-live-demos.sh wave5",
    "cofhe:wait": "node scripts/cofheWait.js",
    "demo:preflight": "NODE_OPTIONS='--dns-result-order=ipv4first' node scripts/demoPreflight.js",
    "demo:preflight:strict": "NODE_OPTIONS='--dns-result-order=ipv4first' node scripts/demoPreflight.js --strict",
    "wave4:live:wait": "NODE_OPTIONS='--dns-result-order=ipv4first' node scripts/cofheWait.js && npm run wave4:live"
  },
  "devDependencies": {
    "@cofhe/hardhat-plugin": "^0.5.2",
    "@cofhe/sdk": "^0.5.2",
    "@fhenixprotocol/contracts": "^0.3.1",
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "chai": "^4.5.0",
    "ethers": "^6.16.0",
    "fhenixjs": "^0.4.1",
    "hardhat": "^2.28.6"
  },
  "dependencies": {
    "dotenv": "^16.3.1"
  }
}
