{
  "name": "fhe-oracle-bridge",
  "version": "1.0.0",
  "description": "Privacy-preserving price oracle using Fhenix FHE",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy:local": "hardhat run scripts/deploy.js --network hardhat",
    "deploy:helium": "hardhat run scripts/deploy.js --network helium",
    "deploy:arbitrum-sepolia": "NODE_OPTIONS='--dns-result-order=ipv4first' hardhat run scripts/deploy.js --network arbitrumSepolia",
    "deploy:base-sepolia": "NODE_OPTIONS='--dns-result-order=ipv4first' hardhat run scripts/deploy.js --network baseSepolia",
    "submit:local": "hardhat run scripts/submitPrice.js --network hardhat",
    "submit:helium": "hardhat run scripts/submitPrice.js --network helium",
    "submit:arbitrum-sepolia": "NODE_OPTIONS='--dns-result-order=ipv4first' hardhat run scripts/submitPrice.js --network arbitrumSepolia",
    "submit:base-sepolia": "NODE_OPTIONS='--dns-result-order=ipv4first' hardhat run scripts/submitPrice.js --network baseSepolia",
    "feeder:local": "hardhat run scripts/feederDaemon.js --network hardhat",
    "feeder:arbitrum-sepolia": "NODE_OPTIONS='--dns-result-order=ipv4first' hardhat run scripts/feederDaemon.js --network arbitrumSepolia",
    "feeder:base-sepolia": "NODE_OPTIONS='--dns-result-order=ipv4first' hardhat run scripts/feederDaemon.js --network baseSepolia",
    "keeper:arbitrum-sepolia": "NODE_OPTIONS='--dns-result-order=ipv4first' hardhat run scripts/liquidationKeeper.js --network arbitrumSepolia",
    "keeper:base-sepolia": "NODE_OPTIONS='--dns-result-order=ipv4first' hardhat run scripts/liquidationKeeper.js --network baseSepolia",
    "keeper:threshold:arbitrum-sepolia": "NODE_OPTIONS='--dns-result-order=ipv4first' hardhat run scripts/thresholdAlertKeeper.js --network arbitrumSepolia",
    "keeper:threshold:base-sepolia": "NODE_OPTIONS='--dns-result-order=ipv4first' hardhat run scripts/thresholdAlertKeeper.js --network baseSepolia",
    "alert:register:arbitrum-sepolia": "NODE_OPTIONS='--dns-result-order=ipv4first' hardhat run scripts/registerThresholdAlert.js --network arbitrumSepolia",
    "alert:register:base-sepolia": "NODE_OPTIONS='--dns-result-order=ipv4first' hardhat run scripts/registerThresholdAlert.js --network baseSepolia",
    "alert:prepare:arbitrum-sepolia": "NODE_OPTIONS='--dns-result-order=ipv4first' hardhat run scripts/prepareThresholdCheck.js --network arbitrumSepolia",
    "alert:prepare:base-sepolia": "NODE_OPTIONS='--dns-result-order=ipv4first' hardhat run scripts/prepareThresholdCheck.js --network baseSepolia",
    "demo:arbitrum": "bash scripts/run-arbitrum-demo.sh",
    "frontend": "node scripts/serveFrontend.cjs",
    "deploy:frontend:surge": "surge frontend/ https://fhe-oracle-bridge-demo.surge.sh",
    "node": "hardhat node"
  },
  "devDependencies": {
    "@cofhe/hardhat-plugin": "^0.4.0",
    "@cofhe/sdk": "^0.4.0",
    "@fhenixprotocol/contracts": "^0.3.1",
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "chai": "^4.5.0",
    "ethers": "^6.16.0",
    "fhenixjs": "^0.4.1",
    "hardhat": "^2.28.6"
  },
  "dependencies": {
    "dotenv": "^16.3.1"
  }
}
